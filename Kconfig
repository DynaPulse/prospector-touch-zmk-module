# Prospector Touch — touch-enabled USB dongle module

config PROSPECTOR_TOUCH
    bool "Prospector Touch hybrid module"
    default y if SHIELD_PROSPECTOR_TOUCH
    select LVGL if ZMK_DISPLAY

if PROSPECTOR_TOUCH

config PROSPECTOR_TOUCH_ENABLED
    bool "Enable CST816S capacitive touch + swipe gestures"
    default y
    select INPUT
    select INPUT_CST816S
    select INPUT_CST816S_INTERRUPT
    help
      Uses the upstream Zephyr CST816S input driver (compatible
      "hynitron,cst816s"). The display UI reads INPUT_ABS_X/Y + INPUT_BTN_TOUCH
      directly via an input callback and derives swipe/tap gestures that drive
      page navigation, layout, channel and brightness in both modes.

config PROSPECTOR_USE_AMBIENT_LIGHT_SENSOR
    bool "Auto-brightness via APDS9960 ambient light sensor"
    default y
    select SENSOR
    select APDS9960

config PROSPECTOR_FIXED_BRIGHTNESS
    int "Fixed backlight brightness when ALS disabled (1-100)"
    range 1 100
    default 60
    depends on !PROSPECTOR_USE_AMBIENT_LIGHT_SENSOR

config PROSPECTOR_DISPLAY_IDLE_S
    int "Seconds of inactivity before the backlight turns off (0 = never)"
    default 60

config PROSPECTOR_DEFAULT_LAYOUT
    int "Default main-screen layout style (0=Dashboard, 1=Focus, 2=Minimal)"
    range 0 2
    default 0

endif # PROSPECTOR_TOUCH
